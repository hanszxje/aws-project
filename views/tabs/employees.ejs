      <!-- ================= TAB CONTENT: EMPLOYEES ================= -->
      <section id="tab-employees" class="tab-content">
        <div class="filter-bar">
          <div class="filter-group select-store-container">
            <label>Lọc theo cửa hàng:</label>
            <select id="employees-store-filter" class="select-control"></select>
          </div>
          <button id="btn-add-employee" class="btn-primary" style="margin-left: auto; height: 42px;"><i class="fa-solid fa-user-plus"></i> Thêm Nhân Viên</button>
        </div>
        
        <div class="data-grid">
          <div class="table-card">
            <table class="data-table" id="employees-table">
              <thead>
                <tr>
                  <th>Mã Nhân Viên</th>
                  <th>Họ và Tên</th>
                  <th>Cửa hàng</th>
                  <th>Vai trò</th>
                  <th>Hành động</th>
                </tr>
              </thead>
              <tbody></tbody>
            </table>
          </div>
          
          <div class="charts-card">
            <h3><i class="fa-solid fa-chart-column"></i> Thống kê Quy mô Nhân sự</h3>
            <div id="employees-chart"></div>
          </div>
        </div>

        <!-- Edit Employee Modal -->
        <div id="employee-modal" class="modal">
          <div class="modal-content">
            <h3>Cập nhật thông tin Nhân viên</h3>
            <div class="form-group">
              <label for="edit-employee-name">Họ và Tên:</label>
              <input type="text" id="edit-employee-name" class="select-control">
            </div>
            <div class="form-group">
              <label for="edit-employee-role">Vai trò:</label>
              <select id="edit-employee-role" class="select-control">
                <option value="Sales Staff">Sales Staff (Nhân viên bán hàng)</option>
                <option value="Store Manager">Store Manager (Quản lý cửa hàng)</option>
              </select>
            </div>
            <div class="modal-actions">
              <button id="btn-save-employee" class="btn-primary">Lưu thay đổi</button>
              <button id="btn-cancel-employee" class="btn-secondary">Hủy</button>
            </div>
          </div>
        </div>
      </section>
