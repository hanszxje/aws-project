  <!-- ================= MODALS ================= -->
  
  <!-- Add Customer Modal -->
  <div id="customer-modal" class="modal">
    <div class="modal-content">
      <h3>Thêm Khách Hàng Mới</h3>
      <form id="customer-form">
        <div class="form-group">
          <label for="customer-name-input">Họ và Tên:</label>
          <input type="text" id="customer-name-input" required class="select-control" placeholder="Nhập họ và tên...">
        </div>
        <div class="form-group">
          <label for="customer-age-input">Tuổi:</label>
          <input type="number" id="customer-age-input" required min="1" max="120" class="select-control" placeholder="Nhập tuổi...">
        </div>
        <div class="form-group">
          <label for="customer-gender-input">Giới tính:</label>
          <select id="customer-gender-input" required class="select-control">
            <option value="Male">Nam (Male)</option>
            <option value="Female">Nữ (Female)</option>
            <option value="Non-binary">Khác (Non-binary)</option>
          </select>
        </div>
        <div class="form-group">
          <label for="customer-country-input">Quốc gia:</label>
          <input type="text" id="customer-country-input" required class="select-control" placeholder="Ví dụ: Vietnam, USA...">
        </div>
        <div class="modal-actions">
          <button type="submit" class="btn-primary">Thêm mới</button>
          <button type="button" id="btn-cancel-customer" class="btn-secondary">Hủy</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Create Discount Modal -->
  <div id="discount-create-modal" class="modal">
    <div class="modal-content">
      <h3>Tạo Khuyến Mãi Mới</h3>
      <form id="discount-create-form">
        <div class="form-group create-discount-store-container">
          <label for="discount-store-input">Cửa hàng:</label>
          <select id="discount-store-input" required class="select-control"></select>
        </div>
        <div class="form-group">
          <label for="discount-season-input">Tên chương trình:</label>
          <input type="text" id="discount-season-input" required class="select-control" placeholder="Ví dụ: Summer Sale, Winter Sale...">
        </div>
        <div class="form-group">
          <label for="discount-avg-input">Mức chiết khấu trung bình (0.00 - 1.00):</label>
          <input type="number" id="discount-avg-input" required step="0.01" min="0" max="1" class="select-control" placeholder="Ví dụ: 0.15">
        </div>
        <div class="form-group">
          <label for="discount-start-input">Ngày bắt đầu:</label>
          <input type="date" id="discount-start-input" required class="select-control">
        </div>
        <div class="form-group">
          <label for="discount-end-input">Ngày kết thúc:</label>
          <input type="date" id="discount-end-input" required class="select-control">
        </div>
        <div class="modal-actions">
          <button type="submit" class="btn-primary">Tạo mới</button>
          <button type="button" id="btn-cancel-create-discount" class="btn-secondary">Hủy</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Create Employee Modal -->
  <div id="employee-create-modal" class="modal">
    <div class="modal-content">
      <h3>Thêm Nhân Viên Mới</h3>
      <form id="employee-create-form">
        <div class="form-group create-employee-store-container">
          <label for="employee-store-input">Cửa hàng:</label>
          <select id="employee-store-input" required class="select-control"></select>
        </div>
        <div class="form-group">
          <label for="employee-name-input">Họ và Tên:</label>
          <input type="text" id="employee-name-input" required class="select-control" placeholder="Nhập họ và tên...">
        </div>
        <div class="form-group">
          <label for="employee-role-input">Vai trò:</label>
          <select id="employee-role-input" required class="select-control">
            <option value="Sales Staff">Sales Staff (Nhân viên bán hàng)</option>
            <option value="Store Manager">Store Manager (Quản lý cửa hàng)</option>
          </select>
        </div>
        <div class="modal-actions">
          <button type="submit" class="btn-primary">Thêm mới</button>
          <button type="button" id="btn-cancel-create-employee" class="btn-secondary">Hủy</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Product Create/Edit Modal -->
  <div id="product-modal" class="modal">
    <div class="modal-content">
      <h3 id="product-modal-title">Thêm Sản Phẩm Mới</h3>
      <form id="product-form">
        <input type="hidden" id="product-id-input">
        <div class="form-group">
          <label for="product-name-input">Tên sản phẩm:</label>
          <input type="text" id="product-name-input" required class="select-control" placeholder="Ví dụ: Áo thun Polo nam...">
        </div>
        <div class="form-group">
          <label for="product-category-input">Danh mục:</label>
          <select id="product-category-input" required class="select-control">
            <option value="Clothing">Quần áo (Clothing)</option>
            <option value="Shoes">Giày dép (Shoes)</option>
            <option value="Accessories">Phụ kiện (Accessories)</option>
          </select>
        </div>
        <div class="form-group">
          <label for="product-subcategory-input">Danh mục phụ:</label>
          <input type="text" id="product-subcategory-input" required class="select-control" placeholder="Ví dụ: T-Shirts, Sneakers...">
        </div>
        <div class="form-group">
          <label for="product-color-input">Kiểu màu:</label>
          <input type="text" id="product-color-input" required class="select-control" placeholder="Ví dụ: Black, White, Multi...">
        </div>
        <div class="form-group">
          <label for="product-description-input">Mô tả (tiếng Anh):</label>
          <textarea id="product-description-input" required class="select-control" style="height: 80px; padding: 10px; resize: none;" placeholder="Mô tả chi tiết sản phẩm..."></textarea>
        </div>
        <div class="form-group">
          <label for="product-image-input">URL hình ảnh (Tùy chọn):</label>
          <input type="url" id="product-image-input" class="select-control" placeholder="Bỏ trống để tự động sinh ảnh...">
        </div>
        <div class="modal-actions">
          <button type="submit" id="btn-save-product-submit" class="btn-primary">Lưu thay đổi</button>
          <button type="button" id="btn-cancel-product" class="btn-secondary">Hủy</button>
        </div>
      </form>
    </div>
  </div>

  <!-- IT Admin: Add/Edit User Modal -->
  <div id="admin-user-modal" class="modal">
    <div class="modal-content" style="max-width: 450px;">
      <h3 id="admin-user-modal-title">Thêm Tài Khoản Mới</h3>
      <form id="admin-user-form">
        <input type="hidden" id="admin-user-id-input">
        <div class="form-group">
          <label for="admin-user-username-input">Tên đăng nhập:</label>
          <input type="text" id="admin-user-username-input" required class="select-control" placeholder="Nhập tên đăng nhập...">
        </div>
        <div class="form-group" id="admin-user-password-container">
          <label for="admin-user-password-input">Mật khẩu:</label>
          <input type="password" id="admin-user-password-input" class="select-control" placeholder="Nhập mật khẩu...">
        </div>
        <div class="form-group">
          <label for="admin-user-role-input">Vai trò:</label>
          <select id="admin-user-role-input" required class="select-control">
            <option value="IT Admin">IT Admin (Quản trị viên)</option>
            <option value="Director">Director (Giám đốc)</option>
            <option value="Finance/Auditor">Finance/Auditor (Kế toán)</option>
            <option value="Inventory Manager">Inventory Manager (Quản lý Kho)</option>
            <option value="Marketing Manager">Marketing Manager (Quản lý Marketing)</option>
            <option value="Store Manager">Store Manager (Quản lý Cửa hàng)</option>
            <option value="Sales Staff">Sales Staff (Nhân viên bán hàng)</option>
          </select>
        </div>
        <div class="form-group" id="admin-user-store-container">
          <label for="admin-user-store-input">Cửa hàng được gán (Nếu có):</label>
          <select id="admin-user-store-input" class="select-control">
            <option value="">Không gán (Global)</option>
          </select>
        </div>
        <div class="modal-actions">
          <button type="submit" id="btn-save-admin-user" class="btn-primary">Lưu</button>
          <button type="button" id="btn-cancel-admin-user" class="btn-secondary">Hủy</button>
        </div>
      </form>
    </div>
  </div>

  <!-- User Self-Service MFA Security Setup Modal -->
  <div id="mfa-setup-modal" class="modal">
    <div class="modal-content" style="max-width: 450px;">
      <h3>Thiết lập Xác thực 2 lớp (MFA)</h3>
      <div id="mfa-status-view" class="mfa-status-card" style="background: rgba(255,255,255,0.03); padding: 15px; border-radius: 8px; margin-bottom: 20px; border: 1px solid rgba(255,255,255,0.05); text-align: center;">
        <p style="margin: 0; font-size: 15px;">Trạng thái hiện tại: <strong id="mfa-current-status-text" style="color: var(--danger-color);">Đã Tắt</strong></p>
      </div>
      
      <!-- Enable MFA Panel -->
      <div id="mfa-enable-panel" class="hidden">
        <p style="margin-bottom:15px; font-size:13px; color:#9ca3af; line-height: 1.4;">Hãy nhập mã khóa bên dưới vào ứng dụng Google Authenticator trên điện thoại để lấy mã xác nhận.</p>
        <div class="mfa-setup-box" style="margin-bottom: 20px;">
          <div class="form-group">
            <label>Khóa bí mật (Secret Key):</label>
            <div style="display:flex; gap: 8px;">
              <input type="text" id="mfa-secret-key" readonly class="select-control" style="font-family: monospace; font-size: 15px; text-align: center; letter-spacing: 1px; background: rgba(0,0,0,0.2);">
              <button type="button" id="btn-copy-mfa-secret" class="btn-secondary" style="white-space:nowrap; padding: 0 15px;"><i class="fa-solid fa-copy"></i> Copy</button>
            </div>
          </div>
        </div>
        <div class="form-group">
          <label for="mfa-verify-code">Nhập mã OTP xác thực (6 chữ số):</label>
          <input type="text" id="mfa-verify-code" class="select-control" placeholder="Ví dụ: 123456" maxlength="6" style="text-align: center; font-size:18px; letter-spacing: 4px;">
        </div>
        <div class="modal-actions" style="margin-top: 20px;">
          <button type="button" id="btn-confirm-enable-mfa" class="btn-primary" style="width: 100%;">Xác nhận Bật</button>
          <button type="button" id="btn-close-mfa-setup" class="btn-secondary" style="width: 100%;">Hủy</button>
        </div>
      </div>

      <!-- Disable MFA Panel -->
      <div id="mfa-disable-panel" class="hidden">
        <p style="margin-bottom:15px; font-size:13px; color:#9ca3af; line-height: 1.4;">Nhập mã OTP hiện tại từ điện thoại để hủy kích hoạt bảo mật MFA.</p>
        <div class="form-group">
          <label for="mfa-disable-code">Nhập mã OTP xác thực (6 chữ số):</label>
          <input type="text" id="mfa-disable-code" class="select-control" placeholder="Ví dụ: 123456" maxlength="6" style="text-align: center; font-size:18px; letter-spacing: 4px;">
        </div>
        <div class="modal-actions" style="margin-top: 20px;">
          <button type="button" id="btn-confirm-disable-mfa" class="btn-primary" style="background-color: var(--danger-color); width: 100%;">Hủy kích hoạt</button>
          <button type="button" id="btn-close-mfa-disable" class="btn-secondary" style="width: 100%;">Hủy</button>
        </div>
      </div>
    </div>
  </div>
